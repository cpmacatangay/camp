<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.QRS" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.QRS" parent="Base.Theme.QRS" />

    <style name="Theme.QRS.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#006E1C</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.QRS</item>
    </style>
</resources>
