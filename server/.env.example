MONGO_URI=mongodb://localhost:27017/camp-registration
# Generate a strong JWT_SECRET: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32-output-64hexchars
PORT=5000
UPLOAD_DIR=uploads
# CORS_ORIGIN must be set to the frontend origin in production
CORS_ORIGIN=http://localhost:5173
SEED_ADMIN_EMAIL=admin@camp.com
# SEED_ADMIN_PASSWORD will be auto-generated if not set
# SEED_ADMIN_PASSWORD=set-a-strong-password
